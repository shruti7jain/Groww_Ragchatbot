# ──────────────────────────────────────────────────────────────
# Groww Mutual Fund FAQ RAG Chatbot — Environment Variables
# Copy this file to .env and fill in your API keys:
#   cp .env.example .env
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────

# LLM API Keys — all free tier
GEMINI_API_KEY=your_gemini_api_key_here     # get free at aistudio.google.com
GROQ_API_KEY=your_groq_api_key_here         # get free at console.groq.com

# Config
LLM_PROVIDER=gemini                          # gemini | groq
TOP_K_RETRIEVAL=3
SIMILARITY_THRESHOLD=0.5
VECTOR_STORE_TYPE=faiss                      # faiss | chroma

# BGE Embedding Model (runs locally, no API key needed)
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
